API_PORT=8080
API_ENV=development
API_AUTH_MODE=jwt
API_AUTH_JWT_SECRET=replace-with-long-random-secret
API_AUTH_JWT_ISSUER=repomemory-web
API_AUTH_JWT_AUDIENCE=repomemory-api
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:55432/repomemory?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_STATE_SECRET=replace-with-random-long-secret
GITHUB_REDIRECT_URL=http://localhost:3000/integrations/github/callback
GITHUB_OAUTH_SCOPE=repo read:user user:email
